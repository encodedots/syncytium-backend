// This is your Prisma schema file
// Real-Time Data Sync POC - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tenant model for multi-tenancy
model Tenant {
  id         String      @id @default(uuid())
  name       String
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  // Relations
  users      User[]
  pcrRecords PcrRecord[] @relation("TenantPcrRecords")

  @@map("tenants")
}

// User model with local role management
model User {
  id        String   @id @default(uuid())
  auth0Id   String?  @unique @map("auth0_id") // Nullable since we manage roles locally
  email     String   @unique
  name      String
  tenantId  String?  @map("tenant_id") // Optional for ADMIN users
  role      String   // 'ADMIN' | 'MANAGER' | 'VIEWER'
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdPcrs    PcrRecord[] @relation("CreatedBy")
  assignedPcrs   PcrRecord[] @relation("AssignedTo")

  @@index([tenantId])
  @@index([role])
  @@map("users")
}

// Role model for RBAC permissions
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions Json     // Array of permission strings
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("roles")
}

// PCR Record model - Patient Care Record
model PcrRecord {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")

  // Basic Information
  patientId       String   @map("patient_id")  // Patient identifier
  patientName     String   @map("patient_name")
  dateOfBirth     DateTime @map("date_of_birth")
  gender          String   // 'MALE' | 'FEMALE' | 'OTHER'

  // Incident Information
  incidentDate    DateTime @map("incident_date")
  incidentType    String   @map("incident_type")  // 'EMERGENCY' | 'ROUTINE' | 'FOLLOW_UP'
  chiefComplaint  String   @map("chief_complaint")

  // Vital Signs
  bloodPressure   String?  @map("blood_pressure")  // e.g., "120/80"
  heartRate       Int?     @map("heart_rate")      // BPM
  temperature     Float?   @map("temperature")     // Celsius
  respiratoryRate Int?     @map("respiratory_rate") // Breaths per minute
  oxygenSaturation Float?  @map("oxygen_saturation") // SpO2 percentage

  // Assessment & Treatment
  diagnosis       String?  @map("diagnosis")
  treatmentPlan   String?  @map("treatment_plan")
  medications     String?  @map("medications")  // JSON string or comma-separated
  procedures      String?  @map("procedures")   // JSON string or comma-separated

  // Status & Workflow
  status          String   // 'OPEN' | 'IN_PROGRESS' | 'PENDING_REVIEW' | 'COMPLETED' | 'CLOSED'
  priority        String   @default("MEDIUM")  // 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL'

  // Assignment
  assignedTo      String?  @map("assigned_to")
  createdBy       String   @map("created_by")

  // Additional Notes
  notes           String?  @db.Text

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")

  // Relations
  tenant       Tenant @relation("TenantPcrRecords", fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser User?  @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator      User   @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@index([patientId])
  @@index([incidentDate])
  @@index([assignedTo])
  @@index([createdBy])
  @@map("pcr_records")
}
